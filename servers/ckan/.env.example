# DSO CKAN MCP Server — environment variable reference
# Copy this to .env and fill in values. Never commit real secrets.

# ── Read path (Track A, anonymous) ──────────────────────────────────────────
# URL of the CKAN portal. Default: http://localhost:5001
CKAN_URL=http://localhost:5001

# Schema cache TTL in seconds. Default: 3600 (1 hour)
SCHEMA_CACHE_TTL=3600

# ── Write path (Track B — token-gated, dry-run-first) ────────────────────────
# Authentication model: the portal authenticates writes via ckanext-oauth2.
# Write tools send the caller-supplied token as the X-Tapis-Token header.
#
# PRIMARY METHOD — per-call tapis_token argument (recommended):
#   Pass a Tapis OAuth2 JWT as the tapis_token= argument to any write tool.
#   The token travels in the tool-call arguments (caller-supplied, short-lived).
#   Tapis JWTs expire in ~hours; provide a fresh token per session.
#   No env var required when using per-call tokens.
#
# FALLBACK — CKAN_API_TOKEN env var (optional):
#   If tapis_token is not supplied on a call, the server falls back to this env
#   var (also a Tapis OAuth2 JWT, sent as X-Tapis-Token).  Useful for automated
#   workflows where the caller cannot pass a per-call token.
#   NEVER commit this value. Store in a *.secrets file (gitignored), not here.
#   If neither is available, write tools return a clear error (no POST made).
# CKAN_API_TOKEN=

# Allow live write tools against a non-localhost CKAN_URL (production portal).
# Default: false — live writes to production are refused unless this is "true".
# Set to "true" ONLY in production after explicit operator review.
# In development (localhost / 127.0.0.1 / *.dev / *.test), this is not required.
# MCP_ALLOW_PROD_WRITES=false

# Allowed directory for file uploads via schema_create_resource.
# The upload_file path must resolve (via os.path.realpath) within this directory.
# Paths outside this dir, symlink escapes, and sensitive paths (/etc, ~/.ssh,
# ~/.aws) are rejected before any file is opened.
# If unset, file uploads are disabled; metadata-only resource creates still work.
# MCP_UPLOAD_DIR=/tmp/mcp-uploads

# Maximum file upload size in MB.  Must be strictly lower than CKAN's built-in
# limit of CKAN_MAX_UPLOAD_SIZE_MB=100.  Default: 90 MB — leaves headroom below
# CKAN's own limit to avoid silent rejection at the portal boundary.
# MCP_MAX_UPLOAD_MB=90

# ── Transport ──────────────────────────────────────────────────────────────
# "stdio" (default) for local MCP clients, or "http" to serve over HTTP so a
# long-running consumer (e.g. ckan-agent-api) can connect as an MCP client.
# MCP_TRANSPORT=stdio
# HTTP bind — keep loopback unless fronted by an auth proxy. The endpoint is
# UNAUTHENTICATED unless MCP_HTTP_SHARED_SECRET is set; a configured
# CKAN_API_TOKEN then grants ambient write access to any caller on the port.
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=8100
# MCP_HTTP_SHARED_SECRET=change-me-to-a-long-random-string
