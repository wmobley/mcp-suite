# DSO LangSmith MCP Server — environment variable reference
# Copy this to .env and fill in values. Never commit real secrets.

# ── LangSmith credentials ────────────────────────────────────────────────────
# API key from smith.langchain.com → Settings → API Keys.
# Required — all tools will fail without this.
LANGSMITH_API_KEY=lsv2_pt_...

# LangSmith API endpoint. Default: https://api.smith.langchain.com
# Override only for self-hosted LangSmith deployments.
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Workspace ID — only required when using workspace-scoped API keys
# that are not bound to a single workspace.
# LANGSMITH_WORKSPACE_ID=

# ── Transport ──────────────────────────────────────────────────────────────
# "stdio" (default) for local MCP clients, or "http" to serve over HTTP so a
# long-running consumer (e.g. ckan-agent-api) can connect as an MCP client.
# MCP_TRANSPORT=stdio
# HTTP bind — keep loopback unless fronted by an auth proxy.
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=8300
# MCP_HTTP_SHARED_SECRET=change-me-to-a-long-random-string
