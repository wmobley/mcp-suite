# DSO Geo MCP Server — environment variable reference
# Copy this to .env and fill in values. Never commit real secrets.

# ── Tapis / Abaco ────────────────────────────────────────────────────────────
# Pre-registered persistent Abaco actor ID (REQUIRED).
# Register the GHCR image ghcr.io/wmobley/mcp-suite/gdal-actor once; paste
# the resulting actor ID here.  dso-geo never registers actors at runtime.
GEO_ACTOR_ID=abcdef1234567890

# Tapis base URL. Default: https://portals.tapis.io
TAPIS_BASE=https://portals.tapis.io

# Optional env-level Tapis JWT fallback.
# Per-call tapis_token argument is ALWAYS preferred over this env var.
# Emit a startup WARNING (and refuse to start against production) if this
# is set.  Never commit this value — use a *.secrets file (gitignored).
# GEO_TAPIS_TOKEN=

# ── CKAN ─────────────────────────────────────────────────────────────────────
# CKAN portal base URL (used to resolve resource/dataset IDs and for
# pipeline-task CKAN registration of transform outputs).
CKAN_URL=http://localhost:5001

# SSRF guard: the resolved CKAN download URL's hostname must match this value.
# Defaults to the hostname of CKAN_URL if unset.
# Set explicitly when CKAN is behind a proxy or has multiple hostnames.
# GEO_ALLOWED_CKAN_HOST=ckan.example.org

# ── Polling defaults ─────────────────────────────────────────────────────────
# These control how long get_execution_status waits before a single poll call
# times out (not a retry loop — the MCP client drives polling).
# GEO_POLL_TIMEOUT_S=10
# GEO_POLL_RETRIES=1

# ── Transport ─────────────────────────────────────────────────────────────────
# "stdio" (default) for local MCP clients, or "http" to serve over HTTP so a
# long-running consumer (e.g. ckan-agent-api) can connect as a client.
# In http mode MCP_HTTP_SHARED_SECRET is REQUIRED (server refuses to start
# without it) and the bind must be loopback while GEO_TAPIS_TOKEN is set.
# MCP_TRANSPORT=stdio
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=8200
# MCP_HTTP_SHARED_SECRET=change-me-to-a-long-random-string
